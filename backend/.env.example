# Comma-separated list of origins allowed to call the API (CORS).
# The Vite dev server defaults to this; add more if you serve the frontend elsewhere.
ALLOWED_ORIGINS=http://localhost:5173

# Optional advanced anti-bot setup. Only set this if you're running the
# bgutil-ytdlp-pot-provider Node server locally (see README).
# BGU_POT_SERVER_HOST=localhost:4416
