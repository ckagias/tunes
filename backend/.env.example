# Comma-separated list of origins allowed to call the API (CORS).
# The Vite dev server defaults to this; add more if you serve the frontend elsewhere.
ALLOWED_ORIGINS=http://localhost:5173

# Optional advanced anti-bot setup. Only set this if you're running the
# bgutil-ytdlp-pot-provider Node server locally (see README).
# BGU_POT_SERVER_HOST=localhost:4416

# Optional: persistent folder finished downloads get copied into (enables the
# "add to iTunes automatically" feature). Leave unset to keep the app fully
# ephemeral, as it is by default.
# LIBRARY_DIR=C:\Users\you\Music\Tunes

# Optional: auto-add every finished download to classic iTunes for Windows
# (see scripts/README.md). Requires LIBRARY_DIR to be set. Windows-only; a
# no-op elsewhere. The frontend toggle can override this per download.
# AUTO_IMPORT_ITUNES=false
